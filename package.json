{
  "name": "lab-attendance",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "db:deploy": "node prisma/deploy.js",
    "test": "node --test --test-concurrency=1 src/services/*.test.js src/utils/*.test.js src/routes/*.test.js",
    "start": "pm2 startOrRestart ecosystem.config.cjs --env production",
    "start:direct": "node server.js",
    "dev": "node --watch server.js",
    "build:css": "tailwindcss -i tailwind.input.css -o public/tailwind.min.css --minify --content \"views/**/*.html\"",
    "pm2:restart": "pm2 restart crCheckIn --update-env",
    "pm2:stop": "pm2 delete crCheckIn",
    "pm2:logs": "pm2 logs crCheckIn",
    "pm2:status": "pm2 status"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@fastify/cookie": "^9.0.0",
    "@fastify/formbody": "^7.4.0",
    "@fastify/multipart": "^7.7.3",
    "@fastify/rate-limit": "^7.6.0",
    "@fastify/session": "^10.0.0",
    "@fastify/static": "^6.12.0",
    "@fastify/view": "^9.0.0",
    "@prisma/client": "^5.0.0",
    "bcrypt": "^5.1.0",
    "exceljs": "^4.4.0",
    "fastify": "^4.0.0",
    "fastify-plugin": "^5.1.0",
    "nunjucks": "^3.2.4",
    "pinyin-pro": "^3.28.1",
    "pm2": "^6.0.14",
    "prisma": "^5.0.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
