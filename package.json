    "@fastify/session": "^10.0.0",
    "@fastify/static": "^6.12.0",
    "@fastify/view": "^9.0.0",
    "@prisma/client": "^5.0.0",
    "bcrypt": "^5.1.0",
    "exceljs": "^4.4.0",
    "fastify": "^4.0.0",
    "fastify-plugin": "^5.1.0",
    "iconv-lite": "^0.4.24",
    "nunjucks": "^3.2.4",
    "pinyin-pro": "^3.28.1"
