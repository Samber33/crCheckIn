generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Teacher {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  classes      Class[]
}

model Class {
  id            Int            @id @default(autoincrement())
  name          String
  teacherId     Int?
  teacher       Teacher?       @relation(fields: [teacherId], references: [id])
  isArchived    Boolean        @default(false)
  semester      String         @default("")  // 学期，如 "2025秋"、"2026春"
  deletedAt     DateTime?      // 回收站：软删除时间，null=正常
  sortOrder     Int            @default(0) // 教师端班级排序
  createdAt     DateTime       @default(now())
  students      Student[]
  signInConfig  SignInConfig?
  signInRecords SignInRecord[]
  sessions      SignInSession[]
  infoCollection InfoCollection?

  @@index([teacherId])
  @@index([teacherId, isArchived])
  @@index([teacherId, sortOrder])
  @@index([name])
  @@index([deletedAt])
}

model SignInSession {
  id        Int            @id @default(autoincrement())
  classId   Int
  class     Class          @relation(fields: [classId], references: [id])
  label     String         // 如 "2025-03-18 周二 上午 · 一职B4"
  archivedAt DateTime      @default(now())
  records   ArchivedRecord[]

  @@index([classId])
}

model ArchivedRecord {
  id           Int           @id @default(autoincrement())
  sessionId    Int
  session      SignInSession @relation(fields: [sessionId], references: [id])
  studentName  String
  homeClass    String        @default("")
  computerName String
  studentIp    String        @default("")
  signedAt     DateTime

  @@index([sessionId])
}

model Student {
  id            Int           @id @default(autoincrement())
  name          String
  homeClass     String        @default("")   // 行政班级，如"高一3班"
  remark        String        @default("")   // 学生备注，如"体育生"
  photoUrl      String        @default("")   // 学生照片路径
  classId       Int
  class         Class         @relation(fields: [classId], references: [id])
  signInRecords SignInRecord[]
  tags          StudentTag[]

  @@unique([classId, name])
}

model StudentTag {
  id          Int     @id @default(autoincrement())
  studentId   Int
  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId     Int
  tag         String
  color       String  @default("#cc785c") // 标签颜色

  @@unique([classId, studentId, tag])
  @@index([classId])
}

model SignInRecord {
  id           Int      @id @default(autoincrement())
  studentName  String
  studentIp    String   @default("")
  computerName String
  signedAt     DateTime @default(now())
  classId      Int
  class        Class    @relation(fields: [classId], references: [id])
  studentId    Int?
  student      Student? @relation(fields: [studentId], references: [id])

  @@unique([classId, studentName])
  @@index([studentIp])
}

model SignInConfig {
  id                  Int       @id @default(autoincrement())
  classId             Int       @unique
  class               Class     @relation(fields: [classId], references: [id])
  activeStartedAt     DateTime?
  countdownDurationMin Int      @default(30)
}

// 信息收集配置
model InfoCollection {
  id        Int       @id @default(autoincrement())
  classId   Int       @unique
  class     Class     @relation(fields: [classId], references: [id])
  enabled   Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  fields    InfoField[]
}

// 收集字段定义
model InfoField {
  id          Int           @id @default(autoincrement())
  collectionId Int
  collection  InfoCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name        String        // 字段名，如"成绩"、"作业文件"
  type        String        // "text" 或 "attachment"
  required    Boolean       @default(false)
  sortOrder   Int           @default(0)
  responses   InfoResponse[]
}

// 学生提交记录
model InfoSubmission {
  id          Int       @id @default(autoincrement())
  classId     Int
  studentId   Int?
  studentName String
  submittedAt DateTime  @default(now())
  responses   InfoResponse[]

  @@index([classId])
}

// 字段响应值
model InfoResponse {
  id           Int           @id @default(autoincrement())
  submissionId Int
  submission   InfoSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fieldId      Int
  field        InfoField      @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  textValue    String?        // 文本值
  fileUrl      String?        // 附件路径
  createdAt    DateTime       @default(now())
}

// 预设标签模板（管理员可增删改）
model PresetTag {
  id        Int      @id @default(autoincrement())
  tag       String   @unique
  color     String   @default("#cc785c")
  sortOrder Int      @default(0)
}

// 管理员操作审计日志
model AuditLog {
  id        Int      @id @default(autoincrement())
  adminId   Int      // 操作者（管理员）
  action    String   // 操作类型：CREATE_TEACHER, DELETE_TEACHER, RESET_PASSWORD, TRANSFER_CLASS, DELETE_CLASS, ARCHIVE_ALL, BACKUP, RESTORE
  target    String   // 操作目标描述
  detail    String   @default("") // 额外详情（JSON 或文本）
  ip        String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
}
